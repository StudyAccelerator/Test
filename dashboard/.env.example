# A-Level Accelerators HQ. Copy to .env and fill in. Never committed.

# Monzo: create a Confidential OAuth client at developers.monzo.com with
# redirect URL http://localhost:4400/api/monzo/callback
MONZO_CLIENT_ID=
MONZO_CLIENT_SECRET=

# Stripe: optional. A read only restricted key (Balance, Charges) makes the
# money panel always-on instead of a daily snapshot.
# STRIPE_KEY=rk_live_...

# Phone access over home Wi-Fi (not needed with Tailscale). HQ_HOST opens the
# server to the network; HQ_TOKEN is then required, any long random string.
# HQ_HOST=0.0.0.0
# HQ_TOKEN=
